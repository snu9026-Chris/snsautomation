# LoopDrop 환경변수 예시
# 이 파일을 .env.local 로 복사하고 각 값을 채우세요.
# Vercel에도 동일하게 등록 필요 (Production 환경).
#
# ⚠️ 모든 값은 끝에 개행/공백 없이 깨끗하게 — 자세한 함정은 oauth-guide.md #1 참고

# ─────────────────────────────────────────────────────
# 기본 인증 (사이트 자체 로그인 — 모든 기능의 게이트)
# ─────────────────────────────────────────────────────
AUTH_USER=your_login_id
AUTH_PASS=your_login_password

# ─────────────────────────────────────────────────────
# 배포 URL (OAuth redirect_uri 만들 때 사용)
# 로컬: http://localhost:3001 / 프로덕션: https://your-app.vercel.app
# ─────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# ─────────────────────────────────────────────────────
# Supabase (DB + Storage 'media' 버킷)
# ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# ─────────────────────────────────────────────────────
# Vercel Cron (예약 발행 + quota 리셋 보호용 시크릿)
# 아무 랜덤 문자열이면 됨. 추천: openssl rand -hex 32
# ─────────────────────────────────────────────────────
CRON_SECRET=random_64_hex_string

# ─────────────────────────────────────────────────────
# YouTube — Google Cloud Console
# OAuth 클라이언트 (영상 업로드/댓글용) + Data API Key (트렌드 조회용) 둘 다 필요
# ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
YOUTUBE_API_KEY=AIzaSy...

# ─────────────────────────────────────────────────────
# Instagram — developers.facebook.com (Meta 앱)
# ─────────────────────────────────────────────────────
META_APP_ID=15_or_16_digits
META_APP_SECRET=32_hex_chars

# ─────────────────────────────────────────────────────
# Threads — developers.facebook.com (Instagram과 같은 Meta 앱 안에서)
# ─────────────────────────────────────────────────────
THREADS_APP_ID=15_or_16_digits
THREADS_APP_SECRET=32_hex_chars

# ─────────────────────────────────────────────────────
# TikTok — developers.tiktok.com
# ⚠️ Sandbox vs Production 키가 다름. 개발 중엔 Sandbox 사용
# ─────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=sbawxxxxx
TIKTOK_CLIENT_SECRET=xxxxx

# ─────────────────────────────────────────────────────
# X (Twitter) — developer.x.com
# OAuth 2.0 (PKCE). 콘솔의 copy 버튼으로만 복사 (W/w 대소문자 함정)
# ─────────────────────────────────────────────────────
X_CLIENT_ID=xxxxx
X_CLIENT_SECRET=xxxxx

# ─────────────────────────────────────────────────────
# OpenAI — platform.openai.com (AI 캡션/추천/음악 프롬프트)
# ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxx

# ─────────────────────────────────────────────────────
# ACE Music — api.acemusic.ai (음원 생성)
# ─────────────────────────────────────────────────────
ACE_MUSIC_API_KEY=xxxxx
